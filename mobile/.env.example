# URL del backend que consume la app. En desarrollo, el teléfono NO puede usar
# "localhost": pon la IP de tu PC en la red local (mira tu IPv4 con `ipconfig`).
# Debe terminar en /api. Ejemplo:
EXPO_PUBLIC_API_URL=http://192.168.1.100:8000/api

# Teléfono de coordinación (botones Llamar/WhatsApp del perfil). Opcional.
EXPO_PUBLIC_COORDINACION_TEL=+51999888777

# Clave de Google Maps de la app (Maps SDK for Android/iOS). Opcional: en Expo Go
# el mapa ya funciona con la clave de Expo; tu clave propia se usa en builds nativos
# (eas build). Pégala aquí y reconstruye. Se inyecta vía app.config.js.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
