# =============================================================================
# .env.example — PLANTILLA de variables del MONOREPO GeoTrack
# -----------------------------------------------------------------------------
# Copia este archivo como `.env` y rellena los valores reales:
#     cp .env.example .env        (Linux/Mac)
#     copy .env.example .env      (Windows)
# El `.env` real NO debe subirse al repositorio (contiene secretos).
# =============================================================================

# --- Base de datos (db) ---
# OJO: el HOST de la base es "db" (nombre del servicio en docker-compose), NO localhost.
POSTGRES_USER=usuario_db
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=nombre_bd
DATABASE_URL=postgresql://usuario_db:cambia-esta-clave@db:5432/nombre_bd

# --- Seguridad / JWT (backend) ---
# Genera una clave larga y aleatoria, p. ej.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- CORS (backend) ---
# Con Nginx como reverse proxy todo es el mismo origen, así que normalmente no
# hace falta abrir CORS. En producción NO uses '*'.
CORS_ORIGINS=*

# --- Admin inicial (backend: se crea al arrancar si no existe) ---
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=cambia-esta-clave

# --- Frontend (Vite) ---
# Clave de Google Maps del panel (Maps JavaScript API). Se inyecta como build ARG.
# DÉJALA VACÍA para usar OpenStreetMap (gratis); PÉGALA para activar Google Maps en
# el Seguimiento de Conductores ("pega y funciona", con fallback automático).
# (VITE_API_URL y VITE_WS_URL NO van aquí: se fijan como rutas relativas en
#  docker-compose.yml porque Nginx hace el proxy.)
VITE_GOOGLE_MAPS_KEY=

# --- Geocoding del backend (precisión de coordenadas) ---
# Clave de Google Geocoding API (SOLO backend, distinta de la del mapa móvil/web).
# DÉJALA VACÍA para usar Nominatim/OSM (gratis, menos preciso); PÉGALA para geocodificar
# con precisión Google (cientos/mes = $0; ponle tope de cuota en Cloud Console para garantizarlo).
GOOGLE_GEOCODING_KEY=

# --- Bandeja de correos (solicitudes de recojo) ---
# Conecta el correo base de la empresa para LEER (IMAP) y RESPONDER (SMTP) desde
# el panel. Si MAIL_ENABLED=false, la bandeja queda en modo "no configurado" y el
# resto del sistema funciona igual.
#
# GMAIL: activa la verificación en 2 pasos y crea una "Contraseña de aplicación"
#        (https://myaccount.google.com/apppasswords). Usa ESA clave en MAIL_PASSWORD,
#        NO la de tu cuenta. Hosts: IMAP imap.gmail.com:993, SMTP smtp.gmail.com:587.
MAIL_ENABLED=false
MAIL_ADDRESS=correo-de-tu-empresa@gmail.com
MAIL_PASSWORD=contrasena-de-aplicacion
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
MAIL_FOLDER=INBOX
# Identidad de las respuestas enviadas desde el panel.
MAIL_FROM_NAME=SAVA S.A.C.
# Firma que se añade al final de cada respuesta. Usa \n para los saltos de línea.
MAIL_SIGNATURE=Atentamente,\nEquipo de Logística\nSAVA S.A.C.
