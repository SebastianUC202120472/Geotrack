# .env.example — PLANTILLA de variables de entorno (Fase de seguridad)
# ----------------------------------------------------------------------------
# Copia este archivo como `.env` y rellena los valores. El `.env` REAL está en
# .gitignore: NUNCA se sube al repositorio (así no se filtran secretos).
#
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
# ----------------------------------------------------------------------------

# --- Seguridad / JWT ---
# Genera una clave larga y aleatoria, p. ej.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-una-clave-larga-y-aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Base de datos (deben coincidir con docker-compose) ---
POSTGRES_USER=sava_admin
POSTGRES_PASSWORD=sava_password123
POSTGRES_DB=siol_sava_db
DATABASE_URL=postgresql://sava_admin:sava_password123@db:5432/siol_sava_db

# --- CORS: orígenes del frontend permitidos (coma-separado). En producción NO uses '*' ---
CORS_ORIGINS=*

# --- Admin inicial (se crea solo al arrancar si no existe) ---
ADMIN_EMAIL=admin@siol.com
ADMIN_PASSWORD=admin123
