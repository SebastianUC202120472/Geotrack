# =============================================================================
# .gitignore del MONOREPO GeoTrack
# =============================================================================

# --- Secretos / entorno (NUNCA subir) ---
.env
.env.*
!.env.example

# --- Backend (Python) ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
# Evidencias / archivos subidos en runtime (se sirven en /media)
backend/uploads/

# --- Frontend (Node / Vite) ---
node_modules/
dist/
dist-ssr/
*.local
npm-debug.log*

# --- Editores / SO ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.swp

# --- design-sync (sincronización con claude.ai/design) ---
# Scratch regenerable (NO subir). Lo durable de .design-sync/ (config.json,
# NOTES.md, conventions.md, previews/, ds-entry.jsx) SÍ es versionable.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
frontend/.ds-dist/

# --- Configuración local de herramientas (no compartir) ---
.claude/
.superpowers/
docs/superpowers/
CLAUDE.md
CONTEXTO.md
.cursor/
.cursorrules
.aider*
.continue/
.github/copilot-instructions.md
.windsurfrules
*.local.md
